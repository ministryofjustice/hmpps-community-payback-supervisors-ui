{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}

{% extends "./layout.njk" %}

{% set pageTitle = 'Log compliance' %}

{% block beforeForm %}
  <h1>Log compliance</h1>
{% endblock %}

{% block formContent %}
  {% macro form() %}
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">
        {{ govukRadios({
          name: "workQuality",
          fieldset: {
            legend: {
              text: "How was their work quality?",
              classes: "govuk-fieldset__legend--m"
            }
          },
          items: workQualityItems,
          errorMessage: errors.workQuality
        }) }}
      </div>
    </div>
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">
        {{ govukRadios({
          name: "behaviour",
          fieldset: {
            legend: {
              text: "How was their behaviour?",
              classes: "govuk-fieldset__legend--m"
            }
          },
          items: behaviourItems,
          errorMessage: errors.behaviour
        }) }}
      </div>
    </div>
  {%endmacro %}

  {{ form() }}

{% endblock %}
